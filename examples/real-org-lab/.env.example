# Public/dogfood Convinced configuration
CONVINCED_API_BASE=https://app.getconvinced.ai
CONVINCED_DASHBOARD_BASE=https://app.getconvinced.ai
CONVINCED_ORG_SLUG=convinced
CONVINCED_CAMPAIGN_TOKEN=acme-robotics

# Private, disposable ElevenLabs lab agent. Never use a production API key in
# browser code or a NEXT_PUBLIC_* variable.
SAMPLE_ELEVENLABS_AGENT_ID=agent_replace_me
ELEVEN_API_KEY=server_only_replace_me

# A PostHog project token is intentionally public. Never put a PostHog
# personal API key here.
NEXT_PUBLIC_POSTHOG_KEY=phc_replace_me

PORT=4184
